linters: linters_with_defaults(
    line_length_linter                = line_length_linter(80L),
    object_name_linter               = NULL,   # deliberate: Sample_Name, P_ref, .get_chp
    indentation_linter               = NULL,   # deliberate alignment / continuation style
    brace_linter                     = NULL,
    object_usage_linter              = NULL,   # cross-file / formula-NSE false positives; R CMD check covers formals
    commented_code_linter            = NULL,
    semicolon_linter                 = NULL,
    return_linter                    = NULL,
    pipe_consistency_linter          = NULL,
    trailing_blank_lines_linter      = NULL,
    function_left_parentheses_linter = NULL,
    spaces_left_parentheses_linter   = NULL,
    assignment_linter                = NULL
  )
exclusions: list("data-raw")
